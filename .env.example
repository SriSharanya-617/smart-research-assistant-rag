# ==========================================
# Smart Research Assistant - Env Config
# ==========================================

# Logger settings
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# LLM Configuration
# Options: openai, anthropic, ollama, huggingface
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# API Keys (fill these in your local .env file)
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# HUGGINGFACEHUB_API_TOKEN=your_huggingface_api_token_here

# Ollama Settings (Optional, for local LLMs)
OLLAMA_BASE_URL=http://localhost:11434

# Embedding Configuration
# Options: huggingface, openai
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector Store Configuration
# Options: chroma, faiss
VECTOR_STORE_TYPE=chroma
VECTOR_STORE_DIR=./data/vectorstore

# Document Ingestion / Splitting Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_UPLOAD_SIZE_MB=20
